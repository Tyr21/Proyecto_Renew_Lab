{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "Consultorio Renew Lab",
	"version": "../package.json",
	"identifier": "com.premex.consultorio-renew-lab",
	"build": {
		"beforeDevCommand": "npm run dev",
		"devUrl": "http://localhost:1420",
		"beforeBuildCommand": "npm run build",
		"frontendDist": "../dist"
	},
	"app": {
		"windows": [
			{
				"title": "Consultorio Renew Lab",
				"width": 1280,
				"height": 800,
				"dataDirectory": "webview2-data",
				"devtools": true
			}
		],
		"security": {
			"csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: asset: https://asset.localhost; connect-src ipc: http://ipc.localhost; font-src 'self' data:"
		}
	},
	"plugins": {
		"updater": {
			"active": true,
			"endpoints": [
				"https://raw.githubusercontent.com/Tyr21/Proyecto_Renew_Lab/main/docs/releases/latest.json"
			],
			"pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDQwQzIyRTQ2NkFGQ0Q1NjkK\nUldScDFmeHFSaTdDUUZnZWtZbTZwS25ucm5xOGV3UjI1N2s4MlZGUVRlUWg0emt6SVNvblppQXAK"
		}
	},
	"bundle": {
		"active": true,
		"targets": "all",
		"createUpdaterArtifacts": false,
		"windows": {
			"digestAlgorithm": "sha256",
			"timestampUrl": "http://timestamp.digicert.com"
		},
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns",
			"icons/icon.ico"
		]
	}
}
